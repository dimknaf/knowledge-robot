# ============================================
# Knowledge Robot - Backend Environment Template
# ============================================
# Copy this file to backend/.env and fill in your API keys.
# Used by docker-compose.local.yml (loaded as env_file) and by
# `python api.py` when running the backend on the host.

# ---- LLM provider (profile-driven via LiteLLM) ----
# Picks an entry from backend/API/config.py::_LLM_PROFILES.
# Currently only `deepinfra` ships out of the box.
LLM_PROFILE=deepinfra
DEEPINFRA_API_KEY=your-deepinfra-api-key-here

# Optional: override the model string for the active profile
# AGENT_MODEL=deepinfra/google/gemma-4-31B-it

# ---- Agent loop ----
AGENT_MAX_TURNS=15
AGENT_SUBAGENT_MAX_TURNS=30
TOOL_OUTPUT_MAX_CHARS=8000

# ---- Firecrawl (only needed if you use the firecrawl scrape backend) ----
FIRECRAWL_API_KEY=your-firecrawl-api-key-here
FIRECRAWL_MAX_CONTENT_LENGTH=20000
MCP_SERVER_URL=https://mcp.firecrawl.dev
MCP_TIMEOUT=10
MCP_CLIENT_TIMEOUT=20

# ---- Local browser (Playwright + crawl4ai) ----
MIN_NAVIGATION_DELAY=2.0
MAX_NAVIGATION_DELAY=5.0
PAGE_LOAD_TIMEOUT=30000

# ---- Feature flags ----
USE_AGENTIC=true
DEBUG_MODE=false

# ---- Security ----
# API key for X-API-Key header authentication (generate with: openssl rand -hex 32).
# If unset, API key validation is disabled (development mode only).
API_SECRET_KEY=
# Allowed CORS origins (comma-separated, no spaces).
ALLOWED_ORIGINS=http://localhost:3000

# ---- Gunicorn (consumed by backend/API/run.sh) ----
KNOWLEDGE_ROBOT_WORKERS=1
KNOWLEDGE_ROBOT_THREADS=16
KNOWLEDGE_ROBOT_TIMEOUT=600
KNOWLEDGE_ROBOT_BINDING_ADDRESS=0.0.0.0:8080
